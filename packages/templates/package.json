{
  "name": "@vedox/templates",
  "version": "0.1.0",
  "private": true,
  "license": "SEE LICENSE IN LICENSE",
  "description": "Vedox launch templates and frontmatter validation schemas",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "*.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "check": "tsc --noEmit"
  },
  "peerDependencies": {
    "zod": "^3"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vitest": "^3.0.4",
    "zod": "^3.24.1"
  }
}
